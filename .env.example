# ---------------------------------------------------------------------------
# Parking Intelligence Platform — environment configuration template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- App ---
APP_ENV=development
APP_NAME=parking-intelligence
LOG_LEVEL=INFO

# --- Data ---
RAW_DATA_PATH=data/raw/violations_raw.csv
PROCESSED_DATA_PATH=data/processed/processed_data.parquet

# --- PostgreSQL (Docker Compose service: see infra/docker-compose.yml) ---
POSTGRES_USER=parking
POSTGRES_PASSWORD=parking_dev_password
POSTGRES_DB=parking_intelligence
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://parking:parking_dev_password@localhost:5432/parking_intelligence

# --- Redis (caching layer, used from Phase 5+) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Kafka (introduced in Phase 7 — streaming pipeline) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- MLflow (introduced in Phase 9 — model tracking) ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Maps ---
# Leaflet + OpenStreetMap needs no key (default for Phase 1-8).
# Set this only if you later switch to Mapbox tiles.
MAPBOX_ACCESS_TOKEN=
